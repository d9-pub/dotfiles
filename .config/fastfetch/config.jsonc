{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "source": "~/.config/fastfetch/arch.png",
    "type": "auto",
    "width": 20,
    "height": 10
  },
  "modules": [
    "packages",
    "disk",
    "memory",
    "uptime",
    "swap",
    {
      "type": "disk",
      "key": "Age",
      "folders": ["/"],
      "format": "{days} days"
    },
    "break",
    "colors"
  ]
}
